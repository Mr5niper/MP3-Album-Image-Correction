# ---- Build output (PyInstaller) ----
build/
dist/
*.exe

# PyInstaller spec is regenerated on each build
*.spec

# Auto-generated Windows version resource
file_version_info.txt

# ---- Bundled ffmpeg ----
# The ffmpeg binary is large; by default it is not committed. Provide it
# locally at bin\ffmpeg.exe before building. Remove this line if you DO want
# to commit it to the repo (make sure it is an LGPL build - see NOTICE).
bin/ffmpeg.exe

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# ---- Editors / OS ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- Tool output ----
# Timestamped logs written by the app.
resize_album_art_*.log
album_art_*.log
